     **free
       dcl-f Empl_pf1 usage(*input: *output :*update) keyed;
       dcl-f Dsply3 Workstn;
       dcl-s w1empid like(Emp_id);
       *inlr=*on;
       Dow *in03=*off;
         Exfmt dsply3r;
         exsr resetind;
         w1empid=d1empid;
         chain w1empid empl_pf1r;
         if %found();
           d1error='Record Already Exists';
         else;
           if d1empname='';
             *In52=*On;
             d1error='Enter the name';
           elseif d1empsal <= 0;
             *In53=*On;
             d1error='Salary cant be blank';
           else;
             Emp_id=d1empid ;
             Emp_name=d1empname;
             Emp_sal=d1empsal;
             write empl_pf1r;
           endif;
         endif;
       Enddo;
       Begsr resetind;
         *In52=*Off;
         *In53=*Off;
         clear d1error;
       endsr;
