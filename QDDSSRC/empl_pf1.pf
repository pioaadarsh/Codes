                R EMPL_PF1R
                  EMP_ID        10S 0       COLHDG('EMPLOYEE ID')
                                            TEXT('EMPLOYEE ID')
                  EMP_NAME      10A         COLHDG('EMPLOYEE NAME')
                                            TEXT('EMPLOYEE NAME')
                  EMP_SAL       10S 0       COLHDG('EMPLOYEE SALARY')
                                            TEXT('EMPLOYEE SALARY')
                K EMP_ID
